# Everything here is optional — Signal runs with no config at all.

# Turn on the Claude-powered cluster summaries + the morning brief. Off by default
# so the app never spends on the API unless you opt in.
AI_ENABLED=false
ANTHROPIC_API_KEY=

# Where the SQLite file lives. Defaults to backend/data/ locally; set this to a
# persistent volume path in production (e.g. /data on Railway).
# DB_DIR=/data

# Morning brief email (only used when AI_ENABLED=true). Leave blank to skip the email
# and just log the brief. GMAIL_APP_PASSWORD is a Gmail App Password, not your login.
GMAIL_FROM=
GMAIL_APP_PASSWORD=
BRIEF_RECIPIENT=
